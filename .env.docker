# Docker environment — скопировать в .env для docker-compose
DOMAIN=example.com
NODE_ENV=production
PORT=3000
FRONTEND_URL=https://${DOMAIN}

JWT_SECRET=CHANGE_ME_TO_RANDOM_HEX_openssl_rand_hex_32
BCRYPT_ROUNDS=12

DATABASE_URL=postgresql://school:school_pass@db:5432/school

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASS=your_password_here

BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=7
