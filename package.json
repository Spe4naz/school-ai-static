{
  "name": "school-ai-static",
  "version": "1.0.0",
  "description": "Интеллектуальная образовательная платформа",
  "main": "dist/server.js",
  "scripts": {
    "start": "node dist/server.js",
    "dev": "tsx watch server.ts",
    "dev:all": "node scripts/dev.js",
    "prod": "cross-env NODE_ENV=production node dist/server.js",
    "test": "cross-env NODE_ENV=test jest",
    "test:watch": "cross-env NODE_ENV=test jest --watch",
    "test:coverage": "cross-env NODE_ENV=test jest --coverage",
    "test:ci": "cross-env NODE_ENV=ci jest --ci --coverage",
    "test:silent": "cross-env NODE_ENV=test jest --silent",
    "prepare": "husky",
    "build": "npm run build:ts && npm run build:frontend",
    "build:ts": "tsc",
    "build:frontend": "esbuild public/js/main.js --bundle --minify --outfile=public/dashboard.bundle.js",
    "build:dev": "esbuild public/js/main.js --bundle --sourcemap --outfile=public/dashboard.bundle.js",
    "watch": "tsx watch server.ts",
    "watch:frontend": "esbuild public/js/main.js --bundle --sourcemap --outfile=public/dashboard.bundle.js --watch",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit && eslint . --ignore-pattern coverage/ --ignore-pattern backups/ --ignore-pattern dist/ --ignore-pattern public/dashboard.bundle.js",
    "lint:fix": "eslint . --fix --ignore-pattern coverage/ --ignore-pattern backups/ --ignore-pattern dist/ --ignore-pattern public/dashboard.bundle.js",
    "format": "prettier --write \"**/*.{ts,js,json,css,html}\"",
    "format:check": "prettier --check \"**/*.{ts,js,json,css,html}\"",
    "clean": "rm -rf dist coverage backups/*",
    "docker:build": "docker compose build",
    "docker:up": "docker compose --env-file .env up -d",
    "docker:down": "docker compose down",
    "docker:prod": "docker compose --env-file .env up -d",
    "docker:logs": "docker compose logs -f caddy app",
    "docker:rebuild": "docker compose build --no-cache && docker compose --env-file .env up -d"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.4.2",
    "express": "^4.18.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.7",
    "pdfkit": "^0.15.0",
    "pg": "^8.13.0",
    "pino": "^10.3.1",
    "uuid": "^11.1.1",
    "xlsx": "^0.18.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^12.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.9.1",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^8.0.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/parser": "^8.60.0",
    "cross-env": "^10.1.0",
    "esbuild": "^0.28.0",
    "eslint": "^8.57.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^15.5.2",
    "prettier": "^3.2.0",
    "supertest": "^7.2.2",
    "testcontainers": "^12.0.0",
    "ts-jest": "^29.4.11",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3"
  },
  "keywords": [
    "education",
    "ai",
    "school"
  ],
  "author": "",
  "license": "MIT",
  "lint-staged": {
    "*.{ts,js}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,html}": [
      "prettier --write"
    ]
  }
}
